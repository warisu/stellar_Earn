# Justfile: optional task runner for common contract commands
# Requires: just (https://github.com/casey/just)

set shell := ["bash", "-cu"]

crate := "earn-quest"
# resolve first matching wasm in the release target
wasm := "$(ls target/wasm32-unknown-unknown/release/*.wasm 2>/dev/null | head -n1)"

build:
    cargo build --release --target wasm32-unknown-unknown

test:
    cargo test

# Fast unit tests only — same subset the pre-commit hook runs
test-fast:
    cargo test --lib

fmt:
    cargo fmt

clippy:
    cargo clippy --all-targets --all-features -- -D warnings

# Run fmt check + clippy + fast tests (mirrors the pre-commit hook locally)
pre-commit-check:
    cargo fmt --all -- --check
    cargo clippy --all-targets --all-features -- -D warnings
    cargo test --lib

# Install pre-commit hooks into .git/hooks/
install-hooks:
    bash ../../scripts/install-hooks.sh

# Verify hooks are installed
check-hooks:
    bash ../../scripts/install-hooks.sh --check

# Remove project hooks from .git/hooks/
remove-hooks:
    bash ../../scripts/install-hooks.sh --remove

deploy:
    if [ -z "$SOROBAN_SECRET_KEY" ]; then
        echo "SOROBAN_SECRET_KEY is not set"; exit 1
    fi
    WASM=$(ls target/wasm32-unknown-unknown/release/*.wasm | head -n1)
    soroban contract deploy --wasm "$${WASM}" --network ${STELLAR_NETWORK:-testnet} --secret-key "$SOROBAN_SECRET_KEY" --rpc-url "$SOROBAN_RPC_URL"

# Example invoke helper (edit args before use)
invoke-register:
    soroban contract invoke --id ${CONTRACT_ID} --fn register_task --arg id=Q-001 --arg reward_asset=... --arg amount=100 --rpc-url "$SOROBAN_RPC_URL"
