{
  "name": "stellar-earn-subgraph",
  "version": "1.0.0",
  "description": "Subgraph indexer for EarnQuest Soroban contract events on Stellar",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "codegen": "graphql-codegen --config codegen.yml",
    "lint": "eslint src --ext .ts",
    "test": "jest --config jest.config.js"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.1.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-graphql": "^0.9.0",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^4.1.2",
    "@graphql-codegen/typescript-resolvers": "^4.4.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
