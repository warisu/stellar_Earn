# =============================================================================
# EarnQuest Subgraph — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# =============================================================================

# Soroban RPC endpoint
RPC_URL=https://soroban-testnet.stellar.org

# EarnQuest contract ID (required)
CONTRACT_ID=

# Network passphrase (default: Testnet)
# NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# For mainnet: Public Global Stellar Network ; September 2015

# Polling interval in milliseconds
POLL_INTERVAL_MS=5000

# Ledgers per page when querying RPC (max 200)
LEDGERS_PER_PAGE=200

# Start ledger (0 = auto-detect from latest)
START_LEDGER=0

# SQLite database path
DB_PATH=./data/earn-quest-subgraph.db

# GraphQL API port
API_PORT=4000

# Log level (debug, info, warn, error)
LOG_LEVEL=info
